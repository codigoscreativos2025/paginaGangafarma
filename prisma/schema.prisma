datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductOverride {
  id            String    @id @default(cuid())
  codigo        String    @unique
  description   String?
  howToUse      String?
  warnings      String?
  imageUrl      String?
  updatedAt     DateTime  @updatedAt
}

model CartItem {
  id            String    @id @default(cuid())
  userId        String?
  guestId       String?
  codigo        String
  quantity      Int       @default(1)
  addedAt       DateTime  @default(now())
}

model UserActionLog {
  id            String    @id @default(cuid())
  userId        String?
  guestId       String?
  actionType    String    // 'VIEW', 'ADD_TO_CART'
  codigo        String
  timestamp     DateTime  @default(now())
}

model Promotion {
  id            String    @id @default(cuid())
  codigo        String
  title         String?
  description   String?
  discount      Float?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}
